{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce_ideation_readonly.sh"
          }
        ]
      },
      {
        "matcher": "Agent|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/autonomy_gate.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session_context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/track_usage.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post_edit_quality.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/thinking_nudge.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/capture_knowledge.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/track_cost.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/extract_patterns.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/check_predictions.sh"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "mcpServers": {}
}
